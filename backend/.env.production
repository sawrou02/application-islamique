# Variables d'environnement pour Railway
# NE PAS committer ce fichier — configurer ces variables dans Railway Dashboard

PORT=3000
NODE_ENV=production

# Fourni automatiquement par Railway PostgreSQL plugin
# DATABASE_URL=postgresql://...

# Fourni automatiquement par Railway Redis plugin
# REDIS_URL=redis://...

# Générer avec: openssl rand -base64 64
JWT_SECRET=CHANGE_ME_IN_RAILWAY_DASHBOARD
JWT_EXPIRES_IN=7d
